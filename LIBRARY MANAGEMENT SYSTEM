<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Library Management System</title>

<style>
body {font-family:'Segoe UI';margin:0;background:linear-gradient(135deg,#667eea,#764ba2);} 
header {text-align:center;padding:20px;color:white;font-size:32px;font-weight:bold;} 
.container {max-width:1100px;margin:auto;background:white;padding:20px;border-radius:15px;} 
input,select,button {width:100%;padding:10px;margin:8px 0;border-radius:8px;border:1px solid #ccc;} 
button {background:#6a11cb;color:white;font-weight:bold;cursor:pointer;} 
.book {display:flex;gap:15px;background:#f2f2f2;padding:10px;margin:10px 0;border-radius:10px;} 
.book img {width:80px;height:100px;object-fit:cover;} 
.actions button {width:auto;margin-right:10px;} 
.issued {background:#ffdede;} 
.dashboard {display:flex;gap:20px;margin-bottom:20px;} 
.card {flex:1;background:#eee;padding:15px;border-radius:10px;text-align:center;font-weight:bold;} 
</style>
</head>

<body>
<header> LIBRARY MANAGEMENT SYSTEM</header>

<div class="container">

<!-- USER LOGIN -->
<h3>User Login</h3>
<input type="text" id="username" placeholder="Username">
<select id="role">
<option>Student</option>
<option>Admin</option>
</select>
<button onclick="login()">Login</button>
<p id="userInfo"></p>

<!-- DASHBOARD -->
<div class="dashboard">
<div class="card" id="totalBooks">Total Books: 0</div>
<div class="card" id="issuedBooks">Issued: 0</div>
</div>

<!-- ADD BOOK -->
<h3>Add Book (Admin)</h3>
<input type="text" id="title" placeholder="Title">
<input type="text" id="author" placeholder="Author">
<input type="text" id="image" placeholder="Image URL">
<select id="category">
<option>Science</option>
<option>IT</option>
<option>Literature</option>
</select>
<button onclick="addBook()">Add Book</button>

<!-- SEARCH -->
<h3>Search / Filter</h3>
<input type="text" id="search" placeholder="Search" onkeyup="displayBooks()">
<select id="filter" onchange="displayBooks()">
<option value="All">All</option>
<option>Science</option>
<option>IT</option>
<option>Literature</option>
</select>

<!-- LIST -->
<h3>Books</h3>
<div id="bookList"></div>

</div>

<script>
let books = JSON.parse(localStorage.getItem("books")) || [];
let user = null;

function save(){ localStorage.setItem("books", JSON.stringify(books)); }

function login(){
  user = {name:username.value, role:role.value};
  userInfo.innerHTML = `Logged in as <b>${user.name}</b> (${user.role})`;
}

function addBook(){
  if(!user || user.role !== "Admin") return alert("Only admin can add books");

  let b = {id:Date.now(), title:title.value, author:author.value, image:image.value, category:category.value, issued:false, due:null};

  if(!b.title || !b.author) return alert("Fill fields");

  books.push(b);
  save();
  displayBooks();
}

function displayBooks(){
  let list = bookList;
  let searchVal = search.value.toLowerCase();
  let filterVal = filter.value;

  list.innerHTML="";

  let total=0, issued=0;

  books
  .filter(b=>b.title.toLowerCase().includes(searchVal))
  .filter(b=>filterVal==="All" || b.category===filterVal)
  .forEach(b=>{

    total++;
    if(b.issued) issued++;

    let fine = "";
    if(b.due && new Date()>new Date(b.due)) fine = "⚠ Fine!";

    list.innerHTML += `
    <div class="book ${b.issued?'issued':''}">
      <img src="${b.image||'https://via.placeholder.com/80'}">
      <div>
        <h4>${b.title}</h4>
        <p>${b.author}</p>
        <p>${b.category}</p>
        <p>Status: ${b.issued?'Issued':'Available'} ${fine}</p>
        ${b.due?`<p>Due: ${b.due}</p>`:""}
        <div class="actions">
          <button onclick="toggleIssue(${b.id})">${b.issued?'Return':'Issue'}</button>
          <button onclick="deleteBook(${b.id})">Delete</button>
        </div>
      </div>
    </div>`;
  });

  totalBooks.innerText = "Total Books: "+total;
  issuedBooks.innerText = "Issued: "+issued;
}

function toggleIssue(id){
  let b = books.find(x=>x.id===id);

  if(!b.issued){
    let due = new Date();
    due.setDate(due.getDate()+7);
    b.due = due.toISOString().split('T')[0];
  } else {
    b.due = null;
  }

  b.issued = !b.issued;
  save();
  displayBooks();
}

function deleteBook(id){
  books = books.filter(b=>b.id!==id);
  save();
  displayBooks();
}

// load
displayBooks();
</script>

</body>
</html>
